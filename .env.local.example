# Circle API
# Get from Circle admin → Settings → API
CIRCLE_API_TOKEN=
CIRCLE_COMMUNITY_ID=
# Optional: a specific Circle space/list ID to add subscribers to
CIRCLE_AUDIENCE_SPACE_ID=

# Resend — transactional welcome email + post-Code nurture automation
# Get from Resend → API Keys. Same key sends the Day-0 welcome AND enrolls
# the contact in the nurture Audience (which triggers the Automation).
RESEND_API_KEY=
# Optional sender override (defaults to "Juli <team@thrivespancollective.com>")
RESEND_FROM=
# The Resend Audience the post-Code nurture Automation triggers on.
# Create the Audience in Resend, then paste its ID here AND in Vercel env.
RESEND_AUDIENCE_ID=
# Where the "send the DM" pings go (DM Beat A). Defaults to team@thrivespancollective.com.
JULS_NOTIFY_EMAIL=
